# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is in .gitignore.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
PRACTICE_ID=00000000-0000-0000-0000-000000000001
RESEND_API_KEY=

# Klara — the web admin assistant (api/reviews.js ?action=chat). Get a key at
# https://aistudio.google.com/apikey . Required for the chatbot to work.
GEMINI_API_KEY=
# Optional — override the Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=

# Mobile clinical assistant (api/notify.js ?action=ai-ask)
ANTHROPIC_API_KEY=
# Webhook secret for Supabase push-notification triggers (api/notify.js)
NOTIFY_SECRET=
